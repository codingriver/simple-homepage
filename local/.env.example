# ============================================================
# 导航网站本地构建配置（位于 local/ 目录）
# 使用方式：cp local/.env.example local/.env
# 然后修改 local/.env 中的配置
# ============================================================

# ── 容器配置 ──
CONTAINER_NAME=simple-homepage

# ── 端口映射（宿主机端口，容器内默认 58080）──
# 访问地址：http://服务器IP:NAV_PORT
NAV_PORT=58080

# ── 时区 ──
TZ=Asia/Shanghai

# ── 数据持久化目录（宿主机路径）──
# 相对路径基于项目根目录（local/ 的上级）
# 此目录包含：用户数据、站点配置、日志、背景图等
# 重建容器不会丢失数据
DATA_DIR=../data

# ── 可选：注入镜像构建元数据（与 CI 一致，便于调试页显示 commit）──
# 本地可执行：GIT_COMMIT=$(git rev-parse HEAD) BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ) docker compose -f local/docker-compose.yml build
# GIT_COMMIT=
# GIT_REF=
# BUILD_DATE=
# GIT_REPO_URL=https://github.com/codingriver/simple-homepage

# ── Docker 构建代理（可选）──
# BUILD_USE_PROXY=0：构建时显式禁用代理（推荐默认）
# BUILD_USE_PROXY=1：构建时启用下方代理变量
BUILD_USE_PROXY=0
BUILD_PROXY_URL=http://192.168.2.2:7890

# ── 计划任务 / 阿里云 DNS（可选）──
# AccessKey 等在后台「域名解析」中配置，明文保存在 data/dns_config.json
