# ============================================================
# 导航网站本地构建配置（位于 local/ 目录）
# 使用方式：cp local/.env.example local/.env
# 然后修改 local/.env 中的配置
#
# ── 推荐：日常开发（代码热更新 + 内置测试账号 qatest）──
#   在项目根目录执行：
#     bash local/docker-build.sh dev          # 首次或 Dockerfile 变更：构建并启动
#     bash local/docker-build.sh dev start    # 仅重启/拉起容器，不重新 build
#     bash local/docker-build.sh dev logs -f    # 跟日志
#     bash local/docker-build.sh dev down       # 停止
#   开发覆盖见 local/docker-compose.dev.yml（含 NAV_DEV_MODE、挂载源码与 php-dev.ini）
# ── 生产式本地运行（无热更新、无内置测试账号）──
#     bash local/docker-build.sh              # 无参：no-cache 构建 + 启动
# ── 自动化测试容器（Playwright / Lighthouse）──
#     docker compose -f local/docker-compose.yml -f local/docker-compose.dev.yml -f local/docker-compose.test.yml run --rm playwright
#     docker compose -f local/docker-compose.yml -f local/docker-compose.dev.yml -f local/docker-compose.test.yml run --rm lighthouse
# ============================================================

# ── 容器配置 ──
CONTAINER_NAME=simple-homepage

# ── 端口映射（宿主机端口，容器内默认 58080）──
# 访问地址：http://服务器IP:NAV_PORT
NAV_PORT=58080

# ── 时区 ──
TZ=Asia/Shanghai

# ── 数据持久化目录（宿主机路径）──
# 相对路径基于项目根目录（local/ 的上级）
# 此目录包含：用户数据、站点配置、日志、背景图等
# 重建容器不会丢失数据
DATA_DIR=../data

# ── Linux bind mount 权限对齐（可选）──
# 若 data/ 属主不是容器内默认的 1000:1000，可填宿主机目录 owner 的 UID/GID
# 示例：
#   PUID=$(stat -c '%u' data)
#   PGID=$(stat -c '%g' data)
# 留空则不做运行时对齐
# PUID=
# PGID=

# ── 可选：注入镜像构建元数据（与 CI 一致，便于调试页显示 commit）──
# 本地可执行：GIT_COMMIT=$(git rev-parse HEAD) BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ) docker compose -f local/docker-compose.yml build
# GIT_COMMIT=
# GIT_REF=
# BUILD_DATE=
# GIT_REPO_URL=https://github.com/codingriver/simple-homepage

# ── 无人值守首次安装（可选，正式/开发环境均可）──
# 设置合法 ADMIN（2–32 位字母数字下划线横杠）后，首次访问即完成初始化；PASSWORD 可留空（小白免设密码）
# 若定义了 ADMIN 但为空或非法，将忽略无人值守并强制走安装向导
# ADMIN=admin
# PASSWORD=
# NAME=导航中心
# DOMAIN=

# ── 计划任务 / 阿里云 DNS（可选）──
# AccessKey 等在后台「域名解析」中配置，明文保存在 data/dns_config.json
