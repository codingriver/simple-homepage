# Docker 构建时排除的文件
# ============================================================

# 运行时数据（通过 Volume 挂载，不打入镜像）
data/users.json
data/config.json
data/sites.json
data/ip_locks.json
data/.installed
data/backups/
data/logs/
data/favicon_cache/
data/bg/

# 环境配置（敏感信息）
.env

# Git
.git/
.gitignore

# 文档
docs/
*.md

# 开发工具
.vscode/
.idea/
*.log

# 打包脚本（不需要打入镜像）
pack.sh
