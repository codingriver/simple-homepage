# Docker 构建时排除的文件（生产镜像）
# ============================================================

# 运行时数据（通过 Volume 挂载，不打入镜像）
data/
# 旧版目录名（迁移到 data/ 前本地可能仍存在）
nav-data/

# 环境配置（敏感信息）
.env
.env.*

# Git / CI 元数据
.git/
.gitignore
.github/

# 文档与说明
# 仅保留 docs；运行时需要的 nginx-conf 模板必须打包进镜像
docs/
*.md

# 本地开发与测试文件
local/
smoke/
node_modules/
test-artifacts/
playwright-report/
blob-report/
coverage/
.nyc_output/

# 可能在宿主机生成的日志目录/文件
logs/
*.log

# 开发工具与临时缓存
.vscode/
.idea/
*.swp
*.swo
.DS_Store
.cache/

# Python 缓存
python/__pycache__/
*.pyc

# 开发专用配置（生产不用）
local/php-dev.ini

# 部署编排/调试脚本（不需要打入运行镜像）
docker-compose.yml
pack.sh

# PHP 开发依赖（生产运行不需要 composer autoload 外的任何 vendor 包）
vendor/
composer.json
composer.lock

# 测试代码与配置（生产不执行测试）
tests/
phpunit.xml
playwright.config.ts
tsconfig.json
lighthouserc.json
scripts/

# npm 清单（纯开发依赖：Playwright / Lighthouse）
package.json
package-lock.json
