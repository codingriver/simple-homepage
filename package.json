{
  "name": "simple-homepage-test-suite",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:full": "playwright test",
    "test:e2e:full:chromium": "playwright test --project=chromium",
    "test:e2e:full:mobile-chrome": "playwright test --project=mobile-chrome",
    "test:e2e:full:chromium:log": "node scripts/run-playwright-log.cjs",
    "test:e2e:full:mobile": "npm run test:e2e:full:mobile-chrome",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:headed:chromium": "playwright test --project=chromium --headed",
    "test:e2e:headed:mobile-chrome": "playwright test --project=mobile-chrome --headed",
    "test:e2e:headed:mobile": "npm run test:e2e:headed:mobile-chrome",
    "test:perf": "lhci autorun --config=./lighthouserc.json",
    "test:running": "bash scripts/test-running-status.sh"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@lhci/cli": "^0.15.1"
  }
}
