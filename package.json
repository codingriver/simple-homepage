{
  "name": "simple-homepage-test-suite",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test tests/e2e/full",
    "test:e2e:full": "playwright test tests/e2e/full",
    "test:e2e:full:chromium": "playwright test tests/e2e/full --project=chromium",
    "test:e2e:full:mobile": "playwright test tests/e2e/full --project=mobile-chrome",
    "test:e2e:headed": "playwright test tests/e2e/full --headed",
    "test:perf": "lhci autorun --config=./lighthouserc.json"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@lhci/cli": "^0.15.1"
  }
}
