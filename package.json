{
  "name": "simple-homepage-test-suite",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:all": "MOBILE=1 playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:headed:all": "MOBILE=1 playwright test --headed",
    "test:e2e:headed:mobile": "playwright test --project=mobile-chrome --headed",
    "test:perf": "lhci autorun --config=./lighthouserc.json",
    "test:running": "bash scripts/test-running-status.sh"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.54.2",
    "typescript": "^5.9.3"
  }
}
