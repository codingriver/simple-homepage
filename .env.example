# ============================================================
# 导航网站 Docker 环境变量配置
# 复制为 .env 后修改：cp .env.example .env
# ============================================================

# ── 容器配置 ──
CONTAINER_NAME=nav-portal

# ── 端口映射（宿主机端口，容器内固定 80）──
# 访问地址：http://服务器IP:NAV_PORT
NAV_PORT=58080

# ── 时区 ──
TZ=Asia/Shanghai

# ── 数据持久化目录（宿主机路径）──
# 此目录包含：用户数据、站点配置、日志、背景图等
# 重建容器不会丢失数据
#DATA_DIR=./nav-data
DATA_DIR=/volume3/storage/docker/nav-portal/nav-portal/data

# ── Docker 构建代理（可选）──
# BUILD_USE_PROXY=0：构建时显式禁用代理（推荐默认）
# BUILD_USE_PROXY=1：构建时启用下方代理变量
BUILD_USE_PROXY=0
BUILD_PROXY_URL=http://192.168.2.2:7890

